# Machine-local secrets
.env
.env.local
*.local

# Generated by setup/git.sh from .env
# (kept gitignored so the user's identity never gets committed)

# OS / editor cruft
.DS_Store
*.swp
*.swo
*~

# Backup snapshots
.zconfig_backup/

# zconfig engine state (per-machine; not shared)
zconfig.lock
.zconfig.log

# Stray archives — cci alias packs ~/.zconfig/.claude/ on demand
claude-config.tar.gz
