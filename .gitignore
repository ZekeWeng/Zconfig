# Machine-local secrets
.env
.env.local
*.local

# Identity files rendered from .env by tools/workflow/git/render.sh
# (kept gitignored so the user's identity never gets committed)

# OS / editor cruft
.DS_Store
*.swp
*.swo
*~

# Python / tooling caches (also caught by the global excludesfile, but keep the
# repo self-contained for contributors without it)
__pycache__/
*.py[cod]
.ruff_cache/

# Backup snapshots
.zconfig_backup/

# zconfig engine state (per-machine; not shared)
zconfig.lock
.zconfig.log

# Stray archives — cci alias packs ~/.zconfig/.claude/ on demand
claude-config.tar.gz
