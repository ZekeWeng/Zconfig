# Git
GIT_USER_NAME=Name
GIT_USER_EMAIL=email@example.com

# SSH
SSH_KEY_NAME=id_ed25519

# API Keys (optional — leave blank if unused)
# Quote values that contain '#' or whitespace, e.g. KEY="abc#def"
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Tokens (optional)
GITHUB_TOKEN=

# Profile: 'full' (default — downloads tooling, runs brew/apt) or 'corp'
# (terminal styling only, no downloads). Leave unset to keep the CLI override
# working (`ZCONFIG_PROFILE=corp make install` or `make install-corp`).
# Uncomment to persist the choice across runs:
# ZCONFIG_PROFILE=corp
