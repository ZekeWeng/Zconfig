# Git
GIT_USER_NAME=Name
GIT_USER_EMAIL=email@example.com

# SSH
SSH_KEY_NAME=id_ed25519

# API Keys (optional — leave blank if unused)
# Quote values that contain '#' or whitespace, e.g. KEY="abc#def"
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Tokens (optional)
GITHUB_TOKEN=

# Profile: 'full' (default — downloads tooling, runs brew/apt) or 'corp'
# (configs + identity only, no downloads). Override at the CLI:
#   ZCONFIG_PROFILE=corp make install   →   same as `make install-corp`
ZCONFIG_PROFILE=full
