# Ghostty — matched to the Zconfig look: Catppuccin Mocha (same colorscheme as
# Neovim) + JetBrains Mono Nerd Font (the installed Nerd Font cask).

theme = Catppuccin Mocha
font-family = JetBrainsMono Nerd Font
font-size = 14

# Roomy padding and unobtrusive chrome.
window-padding-x = 10
window-padding-y = 10
macos-titlebar-style = tabs

cursor-style = block
mouse-hide-while-typing = true
copy-on-select = clipboard
