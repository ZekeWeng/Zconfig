#!/bin/bash
# zconfig — bootstrap-layer entrypoint for the declarative software engine.
#
# Zero dependencies beyond a Python 3.11+ interpreter (needed for stdlib
# `tomllib`). This script self-locates the repo, finds a suitable python3,
# and hands off to the engine package. Keep logic here minimal — the real
# work lives in engine/ (pure stdlib Python).

set -euo pipefail

# Self-locate: bin/zconfig -> repo root is one dir up. Resolve symlinks so a
# symlinked ~/.local/bin/zconfig still finds the repo.
_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do
    _dir="$(cd -P "$(dirname "$_src")" && pwd)"
    _src="$(readlink "$_src")"
    [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
ZCONFIG_DIR="${ZCONFIG_DIR:-$(cd -P "$(dirname "$_src")/.." && pwd)}"
export ZCONFIG_DIR

# Find a python3 >= 3.11 (tomllib). Xcode's bundled python3 is 3.9, so check
# explicit minor versions before the bare `python3`.
find_python() {
    local candidate
    for candidate in python3.13 python3.12 python3.11 python3; do
        if command -v "$candidate" &> /dev/null \
            && "$candidate" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' 2> /dev/null; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

if ! PY="$(find_python)"; then
    echo "zconfig needs Python 3.11+ (for stdlib tomllib), none found." >&2
    if [[ "$(uname)" == "Darwin" ]]; then
        echo "  Install it with: brew install python" >&2
    else
        echo "  Install it with your package manager, e.g. sudo apt-get install python3" >&2
    fi
    exit 1
fi

exec env PYTHONPATH="$ZCONFIG_DIR${PYTHONPATH:+:$PYTHONPATH}" "$PY" -m engine "$@"
